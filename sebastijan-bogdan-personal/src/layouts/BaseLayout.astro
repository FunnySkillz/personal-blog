---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import sbFavicon from "../assets/SB_Initials_Favicon.svg";

interface Props {
  title: string;
  description: string;
  fullWidth?: boolean;
}

const { title, description, fullWidth = false } = Astro.props;
const pathname = Astro.url.pathname;
const isEnglish = pathname === "/en" || pathname.startsWith("/en/");
---

<!doctype html>
<html lang={isEnglish ? "en" : "de"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={sbFavicon.src} />
    <title>{title}</title>
  </head>
  <body class:list={{ "narrative-home": fullWidth }}>
    <Nav />

    <main class:list={{ "main-full-width": fullWidth }}>
      <slot />
    </main>

    <footer class:list={{ "footer-full-width": fullWidth }}>
      <hr />
      <p>(c) 2026 Sebastijan Bogdan. All rights reserved.</p>
    </footer>
  </body>
</html>
