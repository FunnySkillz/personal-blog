---
import type { HomePageContent } from "../../content/homeContent";

interface Props {
  content: HomePageContent;
}

const { content } = Astro.props;
const experienceLabels = content.experience.themes.slice(0, 4);
const projectLabels = content.projects.stations.map((station) => station.title);
---

<div class="persistent-stage-shell" data-persistent-stage-shell aria-hidden="true">
  <div class="persistent-stage" data-persistent-stage data-stage-mode="hero">
    <svg
      class="persistent-stage-svg"
      viewBox="0 0 980 620"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <g class="persistent-stage-grid" data-stage-base>
        <path data-line-draw data-stage-shared-line d="M56 116H924" />
        <path data-line-draw data-stage-shared-line d="M56 218H924" />
        <path data-line-draw data-stage-shared-line d="M56 320H924" />
        <path data-line-draw data-stage-shared-line d="M56 422H924" />
        <path data-line-draw data-stage-shared-line d="M56 524H924" />
        <path data-line-draw data-stage-shared-line d="M198 72V556" />
        <path data-line-draw data-stage-shared-line d="M490 72V556" />
        <path data-line-draw data-stage-shared-line d="M782 72V556" />
      </g>

      <g class="persistent-stage-shell-shared" data-stage-base>
        <rect x="188" y="138" width="604" height="338" rx="46" data-line-draw data-stage-shared-line />
        <rect x="228" y="176" width="524" height="262" rx="34" data-line-draw data-stage-shared-line />
        <circle cx="490" cy="306" r="104" data-line-draw data-stage-shared-line />
        <circle cx="490" cy="306" r="74" data-line-draw data-stage-shared-line />
        <path d="M228 306H752" data-line-draw data-stage-shared-line />
        <path d="M490 176V438" data-line-draw data-stage-shared-line />
      </g>

      <g data-stage-mode-layer="hero">
        <g>
          <rect x="532" y="132" width="192" height="70" rx="18" data-line-draw data-stage-mode-line="hero" />
          <rect x="546" y="146" width="164" height="42" rx="12" data-line-draw data-stage-mode-line="hero" />
        </g>
        <g>
          <ellipse cx="594" cy="252" rx="142" ry="46" data-line-draw data-stage-mode-line="hero" />
          <ellipse cx="594" cy="252" rx="114" ry="34" data-line-draw data-stage-mode-line="hero" />
        </g>
        <g>
          <rect x="508" y="302" width="248" height="86" rx="18" data-line-draw data-stage-mode-line="hero" />
          <path d="M538 332H728" data-line-draw data-stage-mode-line="hero" />
          <path d="M538 354H708" data-line-draw data-stage-mode-line="hero" />
        </g>
        <path d="M724 168H892" data-line-draw data-stage-mode-line="hero" />
        <path d="M756 346H900" data-line-draw data-stage-mode-line="hero" />
        <circle cx="724" cy="168" r="4" data-line-draw data-stage-mode-line="hero" />
        <circle cx="756" cy="346" r="4" data-line-draw data-stage-mode-line="hero" />
      </g>

      <g data-stage-mode-layer="experience">
        <path d="M292 180V448" data-line-draw data-stage-mode-line="experience" />
        <circle cx="292" cy="240" r="8" data-line-draw data-stage-mode-line="experience" />
        <circle cx="292" cy="306" r="8" data-line-draw data-stage-mode-line="experience" />
        <circle cx="292" cy="372" r="8" data-line-draw data-stage-mode-line="experience" />
        <path d="M300 240H554" data-line-draw data-stage-mode-line="experience" />
        <path d="M300 306H598" data-line-draw data-stage-mode-line="experience" />
        <path d="M300 372H566" data-line-draw data-stage-mode-line="experience" />
        <rect x="566" y="206" width="202" height="60" rx="14" data-line-draw data-stage-mode-line="experience" />
        <rect x="610" y="274" width="176" height="60" rx="14" data-line-draw data-stage-mode-line="experience" />
        <rect x="576" y="342" width="196" height="72" rx="14" data-line-draw data-stage-mode-line="experience" />
      </g>

      <g data-stage-mode-layer="projects">
        <rect x="244" y="186" width="220" height="238" rx="24" data-line-draw data-stage-mode-line="projects" />
        <rect x="436" y="150" width="252" height="274" rx="24" data-line-draw data-stage-mode-line="projects" />
        <rect x="664" y="184" width="160" height="236" rx="24" data-line-draw data-stage-mode-line="projects" />
        <path d="M464 246H436" data-line-draw data-stage-mode-line="projects" />
        <path d="M688 266H664" data-line-draw data-stage-mode-line="projects" />
        <path d="M354 186V128H562" data-line-draw data-stage-mode-line="projects" />
        <path d="M744 184V130H562" data-line-draw data-stage-mode-line="projects" />
        <path d="M354 424V490H744" data-line-draw data-stage-mode-line="projects" />
        <circle cx="354" cy="186" r="4" data-line-draw data-stage-mode-line="projects" />
        <circle cx="744" cy="184" r="4" data-line-draw data-stage-mode-line="projects" />
        <circle cx="354" cy="424" r="4" data-line-draw data-stage-mode-line="projects" />
      </g>
    </svg>

    <ul class="persistent-stage-labels persistent-stage-labels-hero" data-stage-label-group="hero">
      {content.hero.labels.map((label) => (
        <li>{label}</li>
      ))}
    </ul>

    <ul class="persistent-stage-labels persistent-stage-labels-experience" data-stage-label-group="experience">
      {experienceLabels.map((label) => (
        <li>{label}</li>
      ))}
    </ul>

    <ul class="persistent-stage-labels persistent-stage-labels-projects" data-stage-label-group="projects">
      {projectLabels.map((label) => (
        <li>{label}</li>
      ))}
    </ul>
  </div>
</div>
