---
import type { HeroSection } from "../../content/homeContent";
import TechnicalDiagram from "./TechnicalDiagram.astro";

interface Props {
  content: HeroSection;
}

const { content } = Astro.props;
---

<section id="act-hero" class="home-act act-hero" data-act="hero">
  <div class="act-panel act-panel-hero">
    <div class="act-content-col" data-parallax="0.03">
      <p class="act-kicker" data-reveal>{content.actTitle}</p>
      <h1 class="hero-title" data-reveal>{content.heading}</h1>
      <p class="hero-role" data-reveal>{content.roles[0]}</p>
      <p class="hero-role hero-role-alt" data-reveal>{content.roles[1]}</p>
      <p class="hero-copy" data-reveal>{content.intro}</p>
      <p class="hero-copy" data-reveal>{content.outro}</p>
      <a href="#act-experience" class="system-cta" data-reveal>
        {content.cta}
        <span aria-hidden="true">-></span>
      </a>
    </div>

    <div class="hero-diagram-col" aria-hidden="true">
      <TechnicalDiagram variant="hero" className="hero-diagram" />
      <ul class="hero-label-cluster" aria-hidden="true">
        {content.labels.map((label, index) => (
          <li class="hero-label" data-reveal style={`--label-index:${index};`}>
            <span class="hero-label-dot" />
            <span>{label}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
