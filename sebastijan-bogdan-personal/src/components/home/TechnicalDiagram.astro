---
interface Props {
  variant: "hero" | "experience" | "projects" | "toolbox" | "philosophy" | "contact";
  className?: string;
}

const { variant, className = "" } = Astro.props;
---

<svg
  class={`technical-diagram ${className}`}
  viewBox="0 0 960 620"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-hidden="true"
>
  <g class="diagram-grid" data-parallax="0.08">
    <path data-line-draw d="M0 120H960" />
    <path data-line-draw d="M0 240H960" />
    <path data-line-draw d="M0 360H960" />
    <path data-line-draw d="M0 480H960" />
    <path data-line-draw d="M160 0V620" />
    <path data-line-draw d="M320 0V620" />
    <path data-line-draw d="M480 0V620" />
    <path data-line-draw d="M640 0V620" />
    <path data-line-draw d="M800 0V620" />
  </g>

  {variant === "hero" && (
    <g class="diagram-machine hero-machine" data-assemble data-hero-machine>
      <g class="hero-module hero-module-backend" data-hero-module="backend">
        <rect x="496" y="120" width="252" height="84" rx="20" data-line-draw />
        <rect x="508" y="132" width="228" height="60" rx="15" data-line-draw />
        <rect class="hero-module-glow" x="504" y="128" width="236" height="68" rx="16" />
      </g>

      <g class="hero-module hero-module-architecture" data-hero-module="architecture">
        <ellipse cx="626" cy="246" rx="174" ry="56" data-line-draw />
        <ellipse cx="626" cy="246" rx="136" ry="42" data-line-draw />
        <ellipse class="hero-module-glow" cx="626" cy="246" rx="128" ry="34" />
      </g>

      <g class="hero-module hero-module-automation" data-hero-module="automation">
        <rect x="470" y="300" width="310" height="92" rx="20" data-line-draw />
        <path d="M510 322H742" data-line-draw />
        <path d="M510 346H742" data-line-draw />
        <path d="M510 370H700" data-line-draw />
        <rect class="hero-module-glow" x="482" y="312" width="286" height="68" rx="14" />
      </g>

      <g class="hero-module hero-module-performance" data-hero-module="performance">
        <rect x="512" y="414" width="224" height="72" rx="18" data-line-draw />
        <rect x="530" y="430" width="188" height="40" rx="10" data-line-draw />
        <rect class="hero-module-glow" x="522" y="424" width="204" height="52" rx="13" />
      </g>

      <g class="hero-module hero-module-product" data-hero-module="product">
        <path d="M440 528H812" data-line-draw />
        <path d="M456 528L484 498H768L796 528" data-line-draw />
        <path d="M516 498V472H738V498" data-line-draw />
        <rect class="hero-module-glow" x="506" y="472" width="242" height="56" rx="10" />
      </g>

      <path class="hero-connector hero-connector-backend" data-line-draw data-hero-connector="backend" d="M748 152H904" />
      <path class="hero-connector hero-connector-architecture" data-line-draw data-hero-connector="architecture" d="M800 246H930" />
      <path class="hero-connector hero-connector-automation" data-line-draw data-hero-connector="automation" d="M780 352H916" />
      <path class="hero-connector hero-connector-performance" data-line-draw data-hero-connector="performance" d="M512 450H236" />
      <path class="hero-connector hero-connector-product" data-line-draw data-hero-connector="product" d="M812 528H910" />

      <circle class="hero-node hero-node-backend" data-line-draw data-hero-node="backend" cx="748" cy="152" r="5" />
      <circle class="hero-node hero-node-architecture" data-line-draw data-hero-node="architecture" cx="800" cy="246" r="5" />
      <circle class="hero-node hero-node-automation" data-line-draw data-hero-node="automation" cx="780" cy="352" r="5" />
      <circle class="hero-node hero-node-performance" data-line-draw data-hero-node="performance" cx="512" cy="450" r="5" />
      <circle class="hero-node hero-node-product" data-line-draw data-hero-node="product" cx="812" cy="528" r="5" />
    </g>
  )}

  {variant === "experience" && (
    <g class="diagram-machine" data-assemble>
      <path data-line-draw d="M190 80V542" />
      <circle data-line-draw cx="190" cy="188" r="10" />
      <circle data-line-draw cx="190" cy="298" r="10" />
      <circle data-line-draw cx="190" cy="408" r="10" />
      <path data-line-draw d="M198 188H520" />
      <path data-line-draw d="M198 298H600" />
      <path data-line-draw d="M198 408H552" />
      <rect data-line-draw x="528" y="148" width="286" height="74" rx="14" />
      <rect data-line-draw x="608" y="258" width="258" height="74" rx="14" />
      <rect data-line-draw x="560" y="366" width="292" height="88" rx="14" />
      <path data-line-draw d="M0 572H960" />
      <rect data-line-draw x="360" y="510" width="420" height="78" rx="24" />
    </g>
  )}

  {variant === "projects" && (
    <g class="diagram-machine" data-assemble>
      <rect data-line-draw x="96" y="170" width="264" height="268" rx="22" />
      <rect data-line-draw x="342" y="120" width="296" height="312" rx="22" />
      <rect data-line-draw x="620" y="164" width="252" height="268" rx="22" />
      <path data-line-draw d="M360 226H342" />
      <path data-line-draw d="M638 242H620" />
      <path data-line-draw d="M228 170V110H488" />
      <path data-line-draw d="M746 164V96H488" />
      <path data-line-draw d="M228 438V508H746" />
      <circle data-line-draw cx="228" cy="170" r="5" />
      <circle data-line-draw cx="746" cy="164" r="5" />
      <circle data-line-draw cx="228" cy="438" r="5" />
      <circle data-line-draw cx="746" cy="438" r="5" />
    </g>
  )}

  {variant === "toolbox" && (
    <g class="diagram-machine" data-assemble>
      <rect data-line-draw x="114" y="132" width="732" height="356" rx="28" />
      <rect data-line-draw x="148" y="176" width="304" height="122" rx="16" />
      <rect data-line-draw x="506" y="176" width="304" height="122" rx="16" />
      <rect data-line-draw x="148" y="324" width="304" height="122" rx="16" />
      <rect data-line-draw x="506" y="324" width="304" height="122" rx="16" />
      <path data-line-draw d="M452 236H506" />
      <path data-line-draw d="M452 384H506" />
      <path data-line-draw d="M304 298V324" />
      <path data-line-draw d="M658 298V324" />
      <circle data-line-draw cx="452" cy="236" r="4" />
      <circle data-line-draw cx="452" cy="384" r="4" />
      <circle data-line-draw cx="304" cy="324" r="4" />
      <circle data-line-draw cx="658" cy="324" r="4" />
    </g>
  )}

  {variant === "philosophy" && (
    <g class="diagram-machine" data-assemble>
      <path data-line-draw d="M140 286H820" />
      <rect data-line-draw x="290" y="198" width="380" height="176" rx="30" />
      <rect data-line-draw x="334" y="236" width="292" height="100" rx="20" />
      <path data-line-draw d="M290 286H220" />
      <path data-line-draw d="M670 286H740" />
      <circle data-line-draw cx="220" cy="286" r="6" />
      <circle data-line-draw cx="740" cy="286" r="6" />
      <path data-line-draw d="M220 286V182H320" />
      <path data-line-draw d="M740 286V182H640" />
    </g>
  )}

  {variant === "contact" && (
    <g class="diagram-machine" data-assemble>
      <ellipse data-line-draw cx="478" cy="286" rx="242" ry="108" />
      <ellipse data-line-draw cx="478" cy="286" rx="188" ry="76" />
      <ellipse data-line-draw cx="478" cy="286" rx="138" ry="50" />
      <path data-line-draw d="M236 286H96" />
      <path data-line-draw d="M720 286H864" />
      <path data-line-draw d="M478 178V74" />
      <path data-line-draw d="M478 394V526" />
      <circle data-line-draw cx="96" cy="286" r="6" />
      <circle data-line-draw cx="864" cy="286" r="6" />
      <circle data-line-draw cx="478" cy="74" r="6" />
      <circle data-line-draw cx="478" cy="526" r="6" />
    </g>
  )}
</svg>
