    <path data-line-draw d="M640 0V620" />
    <path data-line-draw d="M800 0V620" />
  </g>

  {variant === "hero" && (
    <g class="diagram-machine" data-assemble>
      <ellipse data-line-draw cx="620" cy="180" rx="190" ry="64" />
      <ellipse data-line-draw cx="620" cy="212" rx="178" ry="52" />
      <ellipse data-line-draw cx="620" cy="246" rx="166" ry="46" />
