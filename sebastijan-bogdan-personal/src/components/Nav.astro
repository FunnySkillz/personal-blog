---
const rawPathname = Astro.url.pathname;
const pathname = rawPathname !== "/" && rawPathname.endsWith("/")
  ? rawPathname.slice(0, -1)
  : rawPathname;
const isEnglish = pathname === "/en" || pathname.startsWith("/en/");
const localePrefix = isEnglish ? "/en" : "";
const dePath = isEnglish
  ? pathname.replace(/^\/en(?=\/|$)/, "") || "/"
  : pathname;
const enPath = isEnglish
  ? pathname
  : pathname === "/"
    ? "/en/"
    : `/en${pathname}`;

const isHomeActive = pathname === "/" || pathname === "/en";
const isWritingActive =
  pathname === "/writing" ||
  pathname.startsWith("/writing/") ||
  pathname === "/en/writing" ||
  pathname.startsWith("/en/writing/");
const isProjectsActive =
  pathname === "/projects" ||
  pathname.startsWith("/projects/") ||
  pathname === "/en/projects" ||
  pathname.startsWith("/en/projects/");
const isAboutActive = pathname === "/about" || pathname === "/en/about";
const labels = {
  writing: isEnglish ? "Writing" : "Schreiben",
  projects: isEnglish ? "Projects" : "Projekte",
  about: isEnglish ? "About" : "Ueber"
};
---

<header class="site-header">
  <nav class="nav-wrap" aria-label="Main navigation">
    <a href={`${localePrefix}/` || "/"} class:list={["brand", "nav-link", { active: isHomeActive }]}> 
      Sebastijan Bogdan
    </a>

    <div class="nav-links">
      <a href={`${localePrefix}/writing`} class:list={["nav-link", { active: isWritingActive }]}> 
        {labels.writing}
      </a>
      <a href={`${localePrefix}/projects`} class:list={["nav-link", { active: isProjectsActive }]}> 
        {labels.projects}
      </a>
      <a href={`${localePrefix}/about`} class:list={["nav-link", { active: isAboutActive }]}> 
        {labels.about}
      </a>
    </div>

    <div class="lang-switch" aria-label="Language switch">
      <a href={dePath} aria-current={!isEnglish ? "page" : undefined}>DE</a>
      <span>|</span>
      <a href={enPath} aria-current={isEnglish ? "page" : undefined}>EN</a>
    </div>
  </nav>
  <hr class="nav-divider" />
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg, #fafafa) 94%, white 6%);
    backdrop-filter: blur(8px);
  }

  .nav-wrap {
    width: min(100%, 720px);
    margin: 0 auto;
    padding: 0.95rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 600;
    color: #111111;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
    color: #222222;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #222222;
  }

  .lang-switch a[aria-current="page"] {
    opacity: 0.58;
    pointer-events: none;
  }

  .nav-divider {
    border: 0;
    border-top: 1px solid #e5e7eb;
    margin: 0;
  }

  :global(body.narrative-home) .site-header {
    background: color-mix(in srgb, #ece9e5 90%, #f7f4f1 10%);
  }

  :global(body.narrative-home) .nav-wrap {
    width: min(100%, 1240px);
    padding-left: 1.2rem;
    padding-right: 1.2rem;
  }

  :global(body.narrative-home) .nav-divider {
    border-top-color: #cfd4da;
  }

  @media (max-width: 767px) {
    .nav-wrap {
      width: 100%;
      padding: 0.8rem 1rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.42rem;
    }

    .nav-links {
      font-size: 0.95rem;
      gap: 0.9rem;
    }
  }
</style>
